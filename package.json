{
  "name": "pdf-2-llm",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @pdf-2-llm/pdf2md",
    "check": "npm run rust:test && npm run wasm:build && npm run qa:wasm-size && npm run lint && npm run corpus:validate && npm run corpus:candidates && npm run corpus:analyze && npm run corpus:oracles && npm run corpus:previews && npm run corpus:acceptance && npm run corpus:run && npm run corpus:run:all && npm run corpus:run:text && npm run corpus:run:tables && npm run corpus:run:layout && npm run corpus:run:multilingual && npm run qa:diff-html && npm run qa:diff-html-tables && npm run qa:public-tables && npm run qa:rendered-html && npm run qa:markdown-ast && npm run qa:compare-oracles && npm run qa:reading-order && npm run qa:character-error && npm run qa:unicode-mapping && npm run qa:paragraph-grouping && npm run qa:hyphenation && npm run qa:table-detection && npm run qa:warning-codes && npm run qa:asset-links && npm run qa:running-content && npm run qa:tagged-structure && npm run qa:layout-overlay:smoke && npm run qa:benchmark:smoke && npm run qa:benchmark:table-throughput && npm run qa:benchmark:ocr-throughput && npm run qa:benchmark:startup && npm run qa:benchmark:long-memory && npm run qa:malformed && npm run qa:dependencies && npm run qa:package-size && npm run qa:model-size && npm run qa:performance-regression && npm run fuzz:smoke && npm run build && npm run test:api",
    "ci:build": "npm run wasm:build && npm run build",
    "ci:corpus:smoke": "npm run corpus:validate && npm run corpus:acceptance && npm run corpus:run:text",
    "ci:lint": "npm run lint",
    "ci:rust:test": "npm run rust:test",
    "ci:typescript:test": "npm run test:api",
    "corpus:acceptance": "node scripts/corpus/validate-acceptance.mjs --all --allow-empty",
    "corpus:analyze": "node scripts/corpus/analyze.mjs --all --dry-run",
    "corpus:candidates": "node scripts/corpus/retrieve.mjs --all --dry-run",
    "corpus:generate": "node scripts/corpus/generate-fixtures.mjs",
    "corpus:oracles": "node scripts/corpus/extract-oracles.mjs --all --dry-run",
    "corpus:previews": "node scripts/corpus/render-previews.mjs --all --dry-run",
    "corpus:run": "node scripts/qa/run-corpus.mjs --list",
    "corpus:run:all": "node scripts/qa/run-corpus.mjs --all",
    "corpus:run:layout": "node scripts/qa/run-corpus.mjs --id synthetic-two-column --id synthetic-scientific-two-column --id synthetic-header-footer --id synthetic-footnote --assert-markdown",
    "corpus:run:multilingual": "node scripts/qa/run-corpus.mjs --id synthetic-rtl-text --id synthetic-cjk-text --id synthetic-vertical-writing --assert-markdown",
    "corpus:run:tables": "node scripts/qa/run-corpus.mjs --gate tables-v1 --assert-markdown",
    "corpus:run:text": "node scripts/qa/run-corpus.mjs --gate text-mvp --assert-markdown",
    "corpus:validate": "node scripts/corpus/validate-manifest.mjs",
    "fuzz:smoke": "npm run fuzz:smoke --workspace @pdf-2-llm/pdf2md",
    "lint": "node scripts/qa/lint.mjs",
    "qa:benchmark": "node scripts/qa/benchmark.mjs --gate text-mvp",
    "qa:benchmark:webgpu": "node --expose-gc scripts/qa/benchmark.mjs --id synthetic-scanned-text --id synthetic-searchable-scan-regions --id synthetic-two-column --webgpu-comparison --iterations 1 --warmup 0 --report corpus/reports/webgpu-benchmark.json",
    "qa:benchmark:long-memory": "node --expose-gc scripts/qa/benchmark.mjs --memory-limit-gated --iterations 1 --warmup 0 --report .temp/qa/long-memory-profile.json",
    "qa:benchmark:long-memory:report": "node --expose-gc scripts/qa/benchmark.mjs --memory-limit-gated --iterations 1 --warmup 0 --report corpus/reports/long-memory-profile.json",
    "qa:benchmark:smoke": "npm run qa:benchmark:text-throughput",
    "qa:benchmark:ocr-throughput": "node scripts/qa/benchmark.mjs --gate ocr-v1 --iterations 1 --warmup 0 --report .temp/qa/ocr-throughput-benchmark.json",
    "qa:benchmark:ocr-throughput:report": "node scripts/qa/benchmark.mjs --gate ocr-v1 --iterations 3 --warmup 1 --report corpus/reports/ocr-throughput-benchmark.json",
    "qa:benchmark:startup": "node scripts/qa/startup-benchmark.mjs --iterations 1 --warmup 0 --report .temp/qa/startup-benchmark.json",
    "qa:benchmark:startup:report": "node scripts/qa/startup-benchmark.mjs --iterations 3 --warmup 1 --report corpus/reports/startup-benchmark.json",
    "qa:benchmark:table-throughput": "node scripts/qa/benchmark.mjs --gate tables-v1 --iterations 1 --warmup 0 --report .temp/qa/table-throughput-benchmark.json",
    "qa:benchmark:table-throughput:report": "node scripts/qa/benchmark.mjs --gate tables-v1 --iterations 3 --warmup 1 --report corpus/reports/table-throughput-benchmark.json",
    "qa:benchmark:text-throughput": "node scripts/qa/benchmark.mjs --gate text-mvp --iterations 1 --warmup 0 --report .temp/qa/text-throughput-benchmark.json",
    "qa:benchmark:text-throughput:report": "node scripts/qa/benchmark.mjs --gate text-mvp --iterations 3 --warmup 1 --report corpus/reports/text-throughput-benchmark.json",
    "qa:asset-links": "node scripts/qa/check-asset-links.mjs --report .temp/qa/asset-link-validity.json",
    "qa:asset-links:report": "node scripts/qa/check-asset-links.mjs --report corpus/reports/asset-link-validity.json",
    "qa:character-error": "node scripts/qa/compare-oracles.mjs --character-error-gated --report .temp/qa/character-error.json",
    "qa:character-error:report": "node scripts/qa/compare-oracles.mjs --character-error-gated --report corpus/reports/character-error.json",
    "qa:compare-oracles": "node scripts/qa/compare-oracles.mjs --gate text-mvp",
    "qa:dependencies": "node scripts/qa/check-dependencies.mjs && npm audit --audit-level=moderate --omit=dev",
    "qa:diff-html": "node scripts/qa/diff-html.mjs corpus/expected/synthetic-simple-text.md corpus/expected/synthetic-simple-text.md",
    "qa:diff-html-tables": "node scripts/qa/diff-html-tables.mjs corpus/expected/synthetic-visible-table.md corpus/expected/synthetic-visible-table.md",
    "qa:hyphenation": "node scripts/qa/check-hyphenation-repair.mjs --report .temp/qa/hyphenation-repair-accuracy.json",
    "qa:hyphenation:report": "node scripts/qa/check-hyphenation-repair.mjs --report corpus/reports/hyphenation-repair-accuracy.json",
    "qa:public-tables": "node scripts/qa/compare-public-tables.mjs",
    "qa:layout-overlay:smoke": "node scripts/qa/render-layout-overlays.mjs --id synthetic-two-column --out-dir .temp/layout-overlays",
    "qa:malformed": "node scripts/qa/run-malformed-corpus.mjs",
    "qa:markdown-ast": "node scripts/qa/check-markdown-ast.mjs --report .temp/qa/markdown-ast-diff.json",
    "qa:markdown-ast:report": "node scripts/qa/check-markdown-ast.mjs --report corpus/reports/markdown-ast-diff.json",
    "qa:model-size": "node scripts/qa/check-model-size.mjs --report .temp/qa/model-size-budget.json",
    "qa:model-size:report": "node scripts/qa/check-model-size.mjs --benchmark-report corpus/reports/ocr-throughput-benchmark.json --benchmark-report corpus/reports/webgpu-benchmark.json --report corpus/reports/model-size-budget.json",
    "qa:package-size": "node scripts/qa/check-package-size.mjs --report .temp/qa/package-size-budget.json",
    "qa:package-size:report": "node scripts/qa/check-package-size.mjs --report corpus/reports/package-size-budget.json",
    "qa:paragraph-grouping": "node scripts/qa/check-paragraph-grouping.mjs --report .temp/qa/paragraph-grouping-f1.json",
    "qa:paragraph-grouping:report": "node scripts/qa/check-paragraph-grouping.mjs --report corpus/reports/paragraph-grouping-f1.json",
    "qa:performance-regression": "node scripts/qa/check-performance-regression.mjs --report .temp/qa/performance-regression.json",
    "qa:performance-regression:report": "node scripts/qa/check-performance-regression.mjs --current-text corpus/reports/text-throughput-benchmark.json --current-ocr corpus/reports/ocr-throughput-benchmark.json --current-startup corpus/reports/startup-benchmark.json --current-memory corpus/reports/long-memory-profile.json --report corpus/reports/performance-regression.json",
    "qa:reading-order": "node scripts/qa/compare-oracles.mjs --reading-order-gated",
    "qa:rendered-html": "node scripts/qa/check-rendered-html.mjs --rendered-html-gated",
    "qa:running-content": "node scripts/qa/compare-running-content.mjs --gate layout-v1",
    "qa:tagged-structure": "node scripts/qa/compare-tagged-structure.mjs --tagged-structure-gated",
    "qa:table-detection": "node scripts/qa/check-table-detection.mjs --report .temp/qa/table-detection.json",
    "qa:table-detection:report": "node scripts/qa/check-table-detection.mjs --report corpus/reports/table-detection.json",
    "qa:unicode-mapping": "node scripts/qa/check-unicode-mapping.mjs --report .temp/qa/unicode-mapping-accuracy.json",
    "qa:unicode-mapping:report": "node scripts/qa/check-unicode-mapping.mjs --report corpus/reports/unicode-mapping-accuracy.json",
    "qa:warning-codes": "node scripts/qa/check-warning-codes.mjs --report .temp/qa/warning-code-accuracy.json",
    "qa:warning-codes:report": "node scripts/qa/check-warning-codes.mjs --report corpus/reports/warning-code-accuracy.json",
    "qa:wasm-size": "node scripts/qa/check-wasm-size.mjs --report .temp/qa/wasm-size-budget.json",
    "qa:wasm-size:report": "node scripts/qa/check-wasm-size.mjs --report corpus/reports/wasm-size-budget.json",
    "rust:build:wasm": "cargo build -p pdf2md-core --target wasm32-unknown-unknown --release",
    "rust:build:wasm:threaded": "node scripts/build/build-threaded-wasm.mjs",
    "rust:build:wasm:threaded:required": "node scripts/build/build-threaded-wasm.mjs --required",
    "rust:test": "cargo test --workspace",
    "test:api": "npm run test --workspace @pdf-2-llm/pdf2md",
    "wasm:build": "npm run rust:build:wasm && node scripts/build/copy-wasm.mjs"
  }
}
